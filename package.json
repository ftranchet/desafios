{
  "name": "desafios-mentales",
  "private": true,
  "version": "0.38.0",
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:bundle",
    "build:bundle": "vite build",
    "preview": "vite preview",
    "lint": "node --check scripts/new-game.mjs && node --check scripts/new-game.test.mjs && node --check scripts/generate-icons.mjs && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --omit=dev --audit-level=high",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && npm run test:e2e:run",
    "test:e2e:run": "playwright test",
    "new-game": "node scripts/new-game.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build:bundle && npm run test:e2e:run"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.5"
  }
}
